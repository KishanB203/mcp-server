# ─────────────────────────────────────────────────────────────
# Claude MCP Automation — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Azure DevOps ─────────────────────────────────────────────
# Your Azure DevOps organization name (from dev.azure.com/{ORG})
ADO_ORG=

# Your Azure DevOps project name
ADO_PROJECT=

# Personal Access Token — needs: Work Items (Read/Write/Manage)
# Create at: https://dev.azure.com/{ORG}/_usersSettings/tokens
ADO_PAT=

# Alternative name supported by this project (same value as ADO_PAT)
AZURE_DEVOPS_TOKEN=

# API version (optional, defaults to 7.1)
ADO_API_VERSION=7.1

# ── Figma ────────────────────────────────────────────────────
# Personal access token from Figma account settings
# Create at: https://www.figma.com/settings → Personal access tokens
FIGMA_TOKEN=

# The Figma file key from the URL: figma.com/file/{FILE_KEY}/...
FIGMA_FILE_KEY=

# Optional: Figma project ID for creating new files automatically
# Get from: figma.com/files/project/{PROJECT_ID}
FIGMA_PROJECT_ID=

# ── GitHub (for CLI-based PR creation) ───────────────────────
# GitHub token — only needed if gh CLI is not authenticated
# Create at: https://github.com/settings/tokens
# Requires: repo, pull_requests scopes
GITHUB_TOKEN=

# GitHub repository (used by REST workflow)
REPO_OWNER=
REPO_NAME=

# Optional base branch for PRs
BASE_BRANCH=main

# ── Optional: MCP Server Config ──────────────────────────────
# Port for HTTP transport (if using HTTP instead of stdio)
MCP_PORT=3000

# Default ADO backlog targets for requirement -> User Story/Task generation
DEFAULT_AREA_PATH=Mern Intern
DEFAULT_SPRINT_PATH=Mern Intern\\Team B - Sprint 8
DEFAULT_BACKLOG_TAGS=knowledge-base;policy-module;sprint-8
